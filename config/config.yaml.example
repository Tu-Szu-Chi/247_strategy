app:
  timezone: "Asia/Taipei"
  session_mode: "day_and_night"

database:
  url: "sqlite:///local.db"

finmind:
  base_url: "https://api.finmindtrade.com/api/v4"
  token_env: "FINMIND_TOKEN"
  rps_limit: 1
  retry_limit: 2
  backoff_factor: 2.0
  timeout_seconds: 30

reporting:
  output_dir: "reports"

shioaji:
  api_key_env: "SH_API_KEY"
  secret_key_env: "SH_SECRET_KEY"
  daily_limit_bytes: 524288000
  pause_threshold_ratio: 0.99
  usage_check_interval_seconds: 30.0
  usage_reset_hour: 0
  usage_reset_minute: 0
  usage_reset_buffer_seconds: 60

sync:
  registry_path: "config/symbols.csv"
  requests_per_hour: 6000
  target_utilization: 0.8

kronos:
  enabled: false
  target:
    - "10m:50"
  lookback: 300
  sample_count: 128
  interval_minutes: 1
  temperature: 1.0
  top_k: 0
  top_p: 0.9
  model: "NeoQuasar/Kronos-mini"
  tokenizer: "NeoQuasar/Kronos-Tokenizer-2k"
  model_revision:
  tokenizer_revision:
  device:
  max_context: 512
  output_path: "reports/kronos-live.json"
